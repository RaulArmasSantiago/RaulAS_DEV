---
const { stack } = Astro.props;
---

<div class="flex items-center bg-primary/50 rounded-full p-2">
    {stack === "React" && <img src="/icons/React.svg" alt="" class="w-5 h-5" />}
    {stack === "Astro" && <img src="/icons/Astro.svg" alt="" class="w-5 h-5" />}
    {stack === "Node" && <img src="/icons/Node.svg" alt="" class="w-5 h-5" />}
    {stack === "Mongo" && <img src="/icons/Mongo.svg" alt="" class="w-5 h-5" />}
    {
        stack === "Tailwind" && (
            <img src="/icons/Tailwind.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "Angular" && (
            <img src="/icons/Angular.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "CSharp" && (
            <img src="/icons/CSharp.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "Firebase" && (
            <img src="/icons/Firebase.svg" alt="" class="w-5 h-5" />
        )
    }
    {stack === "n8n" && <img src="/icons/N8n.svg" alt="" class="w-5 h-5" />}
    {
        stack === "NextJs" && (
            <img src="/icons/NextJs.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "NodeJs" && (
            <img src="/icons/NodeJs.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "Postgres" && (
            <img src="/icons/Postgres.svg" alt="" class="w-5 h-5" />
        )
    }
    {
        stack === "TypeScript" && (
            <img src="/icons/TypeScript.svg" alt="" class="w-5 h-5" />
        )
    }
    {stack === "Mysql" && <img src="/icons/Mysql.svg" alt="" class="w-5 h-5" />}
    {
        stack === "Telegram" && (
            <img src="/icons/Telegram.svg" alt="" class="w-5 h-5" />
        )
    }
</div>
