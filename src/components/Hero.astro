---
import HeroImage from "@/assets/img/RaulASDEV.jpg";
import Typewrite from "./Typewrite.astro";
---

<div class="flex flex-col items-center md:flex-row mt-10 gap-6">
    <div
        class="w-full max-w-screen-xl h-full flex flex-col justify-center px-20"
    >
        <span
            class="flex items-center justify-center md:justify-start text-center text-primary text-2xl mb-6 label-tag"
        >
            Desarrollador de software
        </span>
        <h1 class="text-center md:text-left text-5xl font-bold mb-10 mt-2">
            Contruyo soluciones <span class="text-gradient">digitales</span> a la
            medida
        </h1>
        <h1 class="mb-2">
            <Typewrite
                words={[
                    "Desarrollo web",
                    "Aplicaciones móviles",
                    "Automatizaciones",
                ]}
            />
        </h1>
        <p class="text-center md:text-left text-muted-foreground mb-10">
            Transformo ideas en productos digitales funcionales. Desde landing
            pages que generan clientes hasta sistemas que automatizan procesos.
        </p>
        <div
            class="flex justify-center md:justify-start gap-6 items-center py-4"
        >
            <a
                href="#proyectos"
                class="w-40 text-center text-primary-foreground bg-primary rounded-lg py-3 px-4 hover:bg-primary/80"
            >
                Ver proyectos
            </a>
            <a
                href="#contacto"
                class="w-40 text-center text-secondary-foreground bg-secondary rounded border py-3 px-4 rounded-lg hover:bg-secondary/60"
            >
                Contactame
            </a>
        </div>
    </div>
    <div class="hidden md:block w-full h-full flex justify-center items-center">
        <img src={HeroImage.src} alt="Hero" class="w-50" />
    </div>
</div>
