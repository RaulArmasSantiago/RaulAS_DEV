---
import Check from "@/assets/svgs/Check.astro";
const { title, description, price, time, features, pricePerMonth } =
    Astro.props;
---

<div
    class="flex flex-col bg-card rounded-lg p-6 shadow-sm border border-border glow-primary transition-all duration-300"
>
    <h3 class="text-gradient text-2xl font-bold w-full text-center">{title}</h3>
    <p class="text-muted-foreground mt-4 text-center">{description}</p>
    <div class="mt-4">
        <span class="text-primary text-2xl font-bold">Desde: {price}</span>
    </div>
    <ul class="mt-4 space-y-2 flex-1">
        {
            features.map((feature: any) => (
                <li class="flex items-center">
                    <Check />
                    {feature}
                </li>
            ))
        }
    </ul>
    <div class="mt-4">
        <a
            href="#contacto"
            class="flex items-center justify-center bg-primary w-full rounded-lg py-2"
            >Contactame</a
        >
    </div>
</div>
